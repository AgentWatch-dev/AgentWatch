# Local Development Secrets for Cloudflare Wrangler
# Replace these placeholders with your actual keys.
# See SECRETS.md (gitignored) for full documentation.

# Supabase
SUPABASE_URL="<YOUR_SUPABASE_URL>"
SUPABASE_SERVICE_ROLE_KEY="<YOUR_SUPABASE_SERVICE_ROLE_KEY>"

# Authentication
TENANT_TOKEN_MAP='{"YOUR_TOKEN_HERE": "your_tenant_id"}'
ADMIN_SECRET="<YOUR_ADMIN_SECRET>"

# Provider API Keys
OPENAI_API_KEY="sk-<YOUR_OPENAI_API_KEY>"
ANTHROPIC_API_KEY="sk-ant-<YOUR_ANTHROPIC_API_KEY>"
XIAOMI_API_KEY="<YOUR_XIAOMI_API_KEY>"
AZURE_OPENAI_API_KEY="<YOUR_AZURE_OPENAI_API_KEY>"
AWS_ACCESS_KEY_ID="<YOUR_AWS_ACCESS_KEY_ID>"
AWS_SECRET_ACCESS_KEY="<YOUR_AWS_SECRET_ACCESS_KEY>"
AWS_REGION="us-east-1"
GROQ_API_KEY="gsk_<YOUR_GROQ_API_KEY>"
XAI_API_KEY="<YOUR_XAI_API_KEY>"
GEMINI_API_KEY="<YOUR_GEMINI_API_KEY>"


# Payment & Notifications
SLACK_WEBHOOK_URL="<YOUR_SLACK_WEBHOOK_URL>"
RESEND_API_KEY="re_<YOUR_RESEND_API_KEY>"
